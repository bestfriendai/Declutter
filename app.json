{
  "expo": {
    "name": "Declutterly",
    "slug": "declutterly",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "declutterly",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "owner": "declutterly",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/declutterly",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.declutterly.app",
      "appleTeamId": "T2A8YY9YDW",
      "associatedDomains": [
        "applinks:declutterly.app",
        "applinks:*.declutterly.app"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Declutterly needs camera access to capture photos of your spaces for AI analysis",
        "NSPhotoLibraryUsageDescription": "Declutterly needs photo library access to save and load room photos",
        "NSUserNotificationsUsageDescription": "Declutterly sends reminders to help you stay on track with your decluttering goals",
        "NSMicrophoneUsageDescription": "Declutterly may use the microphone for voice notes during cleaning sessions"
      },
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#6366F1"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.declutterly.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "declutterly.app",
              "pathPrefix": "/join"
            },
            {
              "scheme": "https",
              "host": "declutterly.app",
              "pathPrefix": "/room"
            },
            {
              "scheme": "https",
              "host": "declutterly.app",
              "pathPrefix": "/challenge"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#6366F1"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Declutterly to access your camera to capture room photos for AI analysis"
        }
      ],
      "expo-media-library",
      "@react-native-google-signin/google-signin",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6366F1",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
