# Declutterly Environment Variables

# Convex Configuration
# `npx convex dev` populates these values for your local app connection.
CONVEX_DEPLOYMENT=dev:your-deployment-name
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Convex server-side secrets
# Set these with the Convex CLI, for example:
# npx convex env set GEMINI_API_KEY your_gemini_api_key_here

# AI Provider Configuration
# Choose your AI provider: "gemini" or "zai"
EXPO_PUBLIC_AI_PROVIDER=gemini

# Google Gemini API Key (for Gemini provider)
# Get your key at: https://makersuite.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Z.AI GLM-4.6V API Key (for Z.AI provider)
# IMPORTANT: The Z.AI API key is stored server-side as a Convex env variable.
# Set it with: npx convex env set ZAI_API_KEY your_zai_api_key_here
# Do NOT use EXPO_PUBLIC_ZAI_API_KEY (it would be exposed in the client bundle).

# Z.AI Free Tier (set to "true" to use glm-4.6v-flash free model)
EXPO_PUBLIC_ZAI_FREE_TIER=false

# Z.AI Coding Plan (set to "true" if you have a Coding Plan subscription)
# Uses api.z.ai/api/coding/paas/v4 endpoint with 3× usage and 1/7 cost
EXPO_PUBLIC_ZAI_CODING_PLAN=false
