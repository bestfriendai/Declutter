rules_version = '2';

// Declutterly Firestore Security Rules
// Deploy these rules to your Firebase project before production launch
// Run: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasValidDisplayName() {
      return request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 50;
    }

    // User profiles - only owner can read/write their data
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      // User's rooms subcollection
      match /rooms/{roomId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // User's stats subcollection
      match /stats/{statId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // User's settings subcollection
      match /settings/{settingId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // Challenges - creator controls, participants can read and update their progress
    match /challenges/{challengeId} {
      // Anyone authenticated can read challenges they're a participant of
      allow read: if isAuthenticated()
        && (resource.data.isPublic == true
          || resource.data.creatorId == request.auth.uid
          || request.auth.uid in resource.data.participantIds);

      // Anyone authenticated can create a challenge
      allow create: if isAuthenticated()
        && request.resource.data.creatorId == request.auth.uid;

      // Only creator can update challenge settings
      // Participants can only update their own progress
      allow update: if isAuthenticated()
        && (resource.data.creatorId == request.auth.uid
          || (request.auth.uid in resource.data.participantIds
            && onlyUpdatingOwnProgress()));

      // Only creator can delete
      allow delete: if isAuthenticated()
        && resource.data.creatorId == request.auth.uid;
    }

    // Shared rooms - respect privacy settings
    match /sharedRooms/{roomId} {
      allow read: if isAuthenticated()
        && (resource.data.isPublic == true
          || resource.data.ownerId == request.auth.uid
          || request.auth.uid in resource.data.viewerIds);

      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid;

      allow update: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;

      allow delete: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;
    }

    // Body doubling sessions
    match /bodyDoublingSessions/{sessionId} {
      allow read: if isAuthenticated()
        && (resource.data.isPublic == true
          || resource.data.hostId == request.auth.uid
          || request.auth.uid in resource.data.participantIds);

      allow create: if isAuthenticated()
        && request.resource.data.hostId == request.auth.uid;

      allow update: if isAuthenticated()
        && (resource.data.hostId == request.auth.uid
          || request.auth.uid in resource.data.participantIds);

      allow delete: if isAuthenticated()
        && resource.data.hostId == request.auth.uid;
    }

    // User connections (friends)
    match /connections/{connectionId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || resource.data.connectedUserId == request.auth.uid);

      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;

      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // Helper function to check if update only affects own progress
    function onlyUpdatingOwnProgress() {
      let diff = request.resource.data.diff(resource.data);
      return diff.affectedKeys().hasOnly(['participants'])
        && request.resource.data.participants.size() == resource.data.participants.size();
    }
  }
}
