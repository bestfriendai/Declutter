rules_version = '2';

// Declutterly Firebase Storage Security Rules
// Deploy these rules to your Firebase project before production launch
// Run: firebase deploy --only storage

service firebase.storage {
  match /b/{bucket}/o {

    // Helper function to check authentication
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check ownership
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to check file size (max 10MB for images)
    function isValidImageSize() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    // Helper function to check image content type
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    // User's private storage - only they can read/write
    match /users/{userId}/{allPaths=**} {
      // Only owner can read their files
      allow read: if isOwner(userId);

      // Only owner can upload, with size and type restrictions
      allow create: if isOwner(userId)
        && isValidImageSize()
        && isImage();

      // Only owner can update/overwrite
      allow update: if isOwner(userId)
        && isValidImageSize()
        && isImage();

      // Only owner can delete
      allow delete: if isOwner(userId);
    }

    // Room photos - stored under user's folder
    match /users/{userId}/rooms/{roomId}/{fileName} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
        && isValidImageSize()
        && isImage();
    }

    // Shared room photos - public read if room is public
    match /shared/{roomId}/{fileName} {
      // Allow read if the associated sharedRoom document is public
      // Note: This requires a Cloud Function to set custom metadata
      allow read: if resource.metadata['isPublic'] == 'true'
        || isAuthenticated();

      // Only the original uploader can write
      allow write: if isAuthenticated()
        && isValidImageSize()
        && isImage();
    }

    // Profile pictures
    match /users/{userId}/profile/{fileName} {
      // Profile pictures can be read by anyone (for social features)
      allow read: if isAuthenticated();

      // Only owner can upload/update/delete
      allow write: if isOwner(userId)
        && isValidImageSize()
        && isImage();
    }

    // Temporary uploads (for processing)
    match /temp/{userId}/{fileName} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && isValidImageSize();
      // Auto-delete via Cloud Function after processing
      allow delete: if isOwner(userId);
    }
  }
}
